# Django
DJANGO_SETTINGS_MODULE=riskproject.settings.dev
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=UTC

# Development SQLite
SQLITE_NAME=db.sqlite3
SQLITE_TIMEOUT=30

# Production database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# LDAP
LDAP_ENABLED=True
LDAP_SERVER=
LDAP_BASE_DN=
LDAP_DOMAIN=
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_EMAIL_DOMAIN=
LDAP_DEBUG=False
LDAP_SUPERUSER_USERNAMES=
LDAP_SUPERUSER_EMAILS=

# Development-only user seeding when not using LDAP
RISK_SEED_TEMPORARY_PASSWORD=

# AI
OPENAI_API_KEY=
GEMINI_API_KEY=

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=
